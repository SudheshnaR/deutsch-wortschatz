{
  "name": "deutsch-wortschatz",
  "version": "1.0.0",
  "private": true,
  "description": "Deutsch Wortschatz — German vocabulary learning app (A1–C1) with spaced repetition, games, and audio.",
  "scripts": {
    "dev": "npx serve www",
    "sync": "npx cap sync",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android",
    "icons": "npx @capacitor/assets generate --assetPath assets",
    "test": "node tests/run.js",
    "test:report": "node tests/run.js && node tests/gen_report.js",
    "audit": "node tests/audit.js"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^6.0.1",
    "@capacitor-community/text-to-speech": "^5.1.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "serve": "^14.2.3"
  }
}
